{
  "name": "pricescout",
  "version": "0.1.0",
  "private": true,
  "description": "PriceScout — visual-first thrift-store flip scanner. Modeled on ShiftDeck.",
  "scripts": {
    "dev": "next dev -p 3300",
    "build": "npx prisma generate && next build",
    "start": "next start -p 3300",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze": "cross-env ANALYZE=true next build",
    "playwright:install": "playwright install chromium",
    "e2e": "playwright test",
    "demo-qa": "playwright test tests/demo-walkthrough.spec.ts --reporter=list",
    "demo-qa:live": "cross-env PLAYWRIGHT_BASE_URL=https://pricescout.pro playwright test tests/demo-walkthrough.spec.ts --reporter=list"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "bcryptjs": "^2.4.3",
    "jose": "^5.10.0",
    "lucide-react": "^0.439.0",
    "next": "^15.0.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^17.3.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.3.3",
    "@playwright/test": "^1.52.0",
    "@sentry/nextjs": "^9.22.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.5",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^7.0.3",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.47",
    "prisma": "^6.8.2",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.4",
    "typescript": "^5.6.3",
    "vitest": "^3.1.4"
  }
}
