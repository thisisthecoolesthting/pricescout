generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  stripeCustomerId   String?
  subscriptionStatus String?
  foundersTier       Boolean  @default(false)
  deviceLimit        Int      @default(4)
  wpbsGrantedAt      DateTime?
  wpbsExpiresAt      DateTime?
  wpbsSourceIp       String?
  storeAddress       String?
  defaultCurrency    String   @default("USD")
  tagPriceRounding   String   @default("nearest_1")
  defaultScannerRole String   @default("scanner")
  currentPeriodEnd   DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  users              User[]
  devices            Device[]
  scans              Scan[]
  wpbsGrants         WpbsGrant[]
  invites            Invite[]
}

model WpbsGrant {
  id        String   @id @default(cuid())
  email     String
  ip        String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         String
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions     Session[]
  scans        Scan[]
  invitesSent  Invite[]  @relation("InviteSentBy")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Invite {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email          String
  role           String
  token          String    @unique
  expiresAt      DateTime
  sentByUserId   String
  sentBy         User      @relation("InviteSentBy", fields: [sentByUserId], references: [id], onDelete: Cascade)
  redeemedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([tenantId, email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
}

model Device {
  id                 String    @id @default(cuid())
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  installFingerprint String
  lastSeenAt         DateTime?
  status             String
  scans              Scan[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Scan {
  id                   String   @id @default(cuid())
  tenantId             String
  userId               String
  deviceId             String?
  identifyTitle        String?
  identifyCategory     String?
  identifyConfidence   Float?
  compMedian           Float?
  compSampleSize       Int?
  compSource           String?
  verdict              String?
  costBasis            Float?
  netUsd               Float?
  scoreNumeric         Float?
  imageUrl             String?
  scannedAt            DateTime @default(now())
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  device               Device?  @relation(fields: [deviceId], references: [id])
}

/// Partner-only support requests (e.g. WPBS staff). Queryable for a future /admin/partners inbox.
model PartnerSupportTicket {
  id         String    @id @default(cuid())
  partner    String
  name       String
  role       String?
  email      String
  message    String
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  resolvedBy String?
}
