{
  "expo": {
    "name": "PriceScout",
    "slug": "pricescout",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "pricescout",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#11CB9D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "pro.pricescout.app",
      "infoPlist": {
        "NSCameraUsageDescription": "PriceScout uses your camera to identify thrift-store items and look up their resale value.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "pro.pricescout.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-foreground.png",
        "backgroundColor": "#11CB9D"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PriceScout to access your camera so it can identify thrift-store items.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#11CB9D",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": { "origin": false },
      "eas": { "projectId": "" }
    }
  }
}
