# Copy to scripts/dispatch_watcher.env (gitignored) or set in process environment.
# Mikaela budget caps belong in C:\factory-agent-local\.env — duplicated here for documentation.

DISPATCH_MAX_USD=5.0
DISPATCH_DAILY_MAX_USD=50.0

# Local Mikaela HTTP task endpoint (dispatch 029)
MIKAELA_TASK_URL=http://127.0.0.1:7778/task

# PriceScout repo root (spine path, dispatch moves)
PRICESCOUT_ROOT=E:\Projects\pricescout

# Seconds between polls
DISPATCH_WATCHER_INTERVAL=30
